# Bundled Python libs: exclude pip metadata and unneeded packages
bundled/libs/**/__pycache__/**
bundled/libs/**/*.dist-info/**
bundled/libs/bin/**

# pywin32 — Windows COM/API bindings, not needed by LSP or MCP server
bundled/libs/win32/**
bundled/libs/win32com/**
bundled/libs/win32comext/**
bundled/libs/pythonwin/**
bundled/libs/pywin32_system32/**
bundled/libs/isapi/**
bundled/libs/adodbapi/**
bundled/libs/pythoncom.py
bundled/libs/PyWin32.chm
bundled/libs/pywin32.pth
bundled/libs/pywin32.version.txt

# pygments — installed as a transitive dependency; lexers and formatters are
# not used by the bundled tools, so strip them to keep the package small.
bundled/libs/pygments/lexers/**
bundled/libs/pygments/formatters/**

# node_modules: exclude unused build variants from telemetry SDK
node_modules/@microsoft/**/bundle/**
node_modules/@microsoft/**/dist-es5/**
node_modules/@microsoft/**/types/**
node_modules/@nevware21/**/bundle/**

# MCP server: include only the bundled dist output
adams-view-mcp-server/src/**
adams-view-mcp-server/tests/**
adams-view-mcp-server/node_modules/**
adams-view-mcp-server/tsconfig.json
!adams-view-mcp-server/dist/**
!adams-view-mcp-server/package.json

# adams_skills submodule: exclude dev-only content, keep skill content
resources/adams_skills/.github/**
resources/adams_skills/.vscode/**
resources/adams_skills/.agents/**
resources/adams_skills/.playwright-mcp/**
resources/adams_skills/.git/**
resources/adams_skills/dist/**
resources/adams_skills/adams-skills-api/**
resources/adams_skills/*-workspace/**
resources/adams_skills/install.ps1
resources/adams_skills/install.sh
resources/adams_skills/AGENTS.md
resources/adams_skills/CLAUDE.md
resources/adams_skills/README.md
resources/adams_skills/LICENSE
resources/adams_skills/.gitignore
resources/adams_skills/.gitmodules
resources/adams_skills/skills/*/evals/**

!USER_ENTERED_COMMAND linked_refs
! =============================================================================
!  linked_refs.mac — Linked Object References Demo
!  ─────────────────────────────────────────────────────────────────────────
!  PURPOSE
!    Demonstrates every kind of navigable reference in the Adams CMD LSP:
!
!    • Macro parameters  (.model_1, first_arm, etc.)
!        Ctrl+Click any usage  → jumps to the !$param definition line
!        Ctrl+Click the def    → shows ALL usages in the peek window
!        Shift+F12 anywhere    → "Find All References" panel
!
!    • Adams object names  (.linked_demo.arm1, .linked_demo.arm1.J1_I, …)
!        Ctrl+Click a name     → jumps to the command that first creates it
!        Ctrl+Click the create → shows all subsequent uses
!
!    • Variable references  ($_self.arm1_len, $_self.stiffness, …)
!        Ctrl+Click a $var     → jumps to the matching  variable set  line
!
!  HOW TO NAVIGATE
!    • Ctrl+Click (or F12)  — Go to Definition / Go to References
!    • Shift+F12            — Find All References
!    • Alt+← / Alt+→        — Navigate back / forward
! =============================================================================
!MACRO NAME:  linked_refs
!HELP_STRING: Build a two-link pendulum with a spring-damper (reference demo)
!AUTHOR:      ben.thornton
!END_OF_PARAMETERS

! =============================================================================
! 0. UNITS & MODEL
! =============================================================================

defaults units  &
    length = mm  &
    angle  = deg  &
    force  = newton  &
    mass   = kg  &
    time   = sec

model create model_name = .model_1     


! =============================================================================
! 1. PARAMETRIC DESIGN VARIABLES
!    Use  variable set  so the LSP can resolve  $_self.xxx  references later.
!    Ctrl+Click any $_self.arm1_len usage below → jumps to this block.
! =============================================================================

variable create  &
    variable_name = .model_1.arm1_len  &
    real_value    = 300      

variable create  &
    variable_name = .model_1.arm2_len  &
    real_value    = 300      ! same param, two objects — Shift+F12 shows both

variable create  &
    variable_name = .model_1.arm_mass  &
    real_value    = 0.5

variable create  &
    variable_name = .model_1.stiffness  &
    real_value    = 5.0

variable create  &
    variable_name = .model_1.damping  &
    real_value    = 0.05


! =============================================================================
! 2. PARTS & MARKERS
!    Parts use first_arm / second_arm (Ctrl+Click → !first_arm / !second_arm).
!    Marker names are Adams object refs — created here, used in §3 and §4.
! =============================================================================

! ── ARM 1 ──────────────────────────────────────────────────────────────────

part create rigid_body name_and_position  &
    part_name = .model_1.first_arm         &    ! ← first_arm used here (def 1/N)
    location  = 0, 0, 0

! Centre-of-mass marker at the arm midpoint.
! Ctrl+Click  .model_1.first_arm.cm  anywhere below → jumps to this  marker create.
marker create  &
    marker_name = .model_1.first_arm.cm    &
    location    = (eval(.model_1.arm1_len * 0.5)), 0, 0   ! uses variable .model_1.arm1_len

part modify rigid_body mass_properties  &
    part_name                = .model_1.first_arm         &
    mass                     = (eval(.model_1.arm_mass))   &
    center_of_mass_marker    = .model_1.first_arm.cm      &   ! ← object ref (Ctrl+Click → marker create above)
    ixx                      = 1  &
    iyy                      = (eval(.model_1.arm_mass * (.model_1.arm1_len**2) / 12))  &
    izz                      = (eval(.model_1.arm_mass * (.model_1.arm1_len**2) / 12))

! Pivot marker at the arm root (will be used in the revolute joint).
marker create  &
    marker_name = .model_1.first_arm.pivot_I  &
    location    = 0, 0, 0

! Tip marker — will be referenced as the upper attachment of the spring.
marker create  &
    marker_name = .model_1.first_arm.tip  &
    location    = (eval(.model_1.arm1_len)), 0, 0   ! .model_1.arm1_len ref 2

! ── ARM 2 ──────────────────────────────────────────────────────────────────

part create rigid_body name_and_position  &
    part_name = .model_1.second_arm  &              ! ← second_arm used here
    location  = (eval(.model_1.arm1_len)), 0, 0    ! offset by arm1 length

marker create  &
    marker_name = .model_1.second_arm.cm  &
    location    = (eval(.model_1.arm1_len + .model_1.arm2_len * 0.5)), 0, 0

part modify rigid_body mass_properties  &
    part_name                = .model_1.second_arm  &
    mass                     = (eval(.model_1.arm_mass))  &
    center_of_mass_marker    = .model_1.second_arm.cm  &
    ixx                      = 1  &
    iyy                      = (eval(.model_1.arm_mass * (.model_1.arm2_len**2) / 12))  &
    izz                      = (eval(.model_1.arm_mass * (.model_1.arm2_len**2) / 12))

! Root pivot of arm2 — mounts onto the tip of arm1.
marker create  &
    marker_name = .model_1.second_arm.pivot_I  &
    location    = (eval(.model_1.arm1_len)), 0, 0

! Spring attachment marker at arm2 midpoint.
marker create  &
    marker_name = .model_1.second_arm.spring_J  &
    location    = (eval(.model_1.arm1_len + .model_1.arm2_len * 0.5)), 0, 0


! =============================================================================
! 3. CONSTRAINTS
!    Ctrl+Click on joint I/J markers → back to the  marker create  lines above.
! =============================================================================

! Ground pivot for arm1 — uses  .model_1.first_arm.pivot_I
constraint create joint revolute  &
    joint_name = .model_1.rev1         &
    i_marker   = .model_1.first_arm.pivot_I  &   
    j_marker   = ground.ref_point

! Elbow pivot between arm1 tip and arm2 root.
! Ctrl+Click  .model_1.first_arm.tip  → tip marker created in §2.
constraint create joint revolute  &
    joint_name = .model_1.rev2         &
    i_marker   = .model_1.first_arm.tip       &   ! ← second use of .tip marker
    j_marker   = .model_1.second_arm.pivot_I


! =============================================================================
! 4. FORCES
!    Spring-damper between arm1 tip and arm2 midpoint.
!    Uses 5.0 and 0.05 params (Ctrl+Click → !5.0 / !0.05).
!    Also uses .model_1.stiffness / .model_1.damping variables (Ctrl+Click → §1 var create).
! =============================================================================

force create element translational_spring_damper  &
    spring_damper_name          = .model_1.tsd1             &
    i_marker                    = .model_1.first_arm.tip   &   
    j_marker                    = .model_1.second_arm.spring_J  &
    stiffness                   = (eval(.model_1.stiffness))    &   
    damping                     = (eval(.model_1.damping))      &   
    displacement_at_preload     = (eval(.model_1.arm2_len * 0.5))



! =============================================================================
! 5. MEASURES
!    Measure the angle at each joint and the spring deformation.
!    Object names (.model_1.rev1, .model_1.rev2, .model_1.tsd1) all Ctrl+Click back
!    to their creation commands in §3 / §4.
! =============================================================================

measure create object  &
    measure_name    = .model_1.angle_rev1  &
    object          = .model_1.rev1  &         
    component       = z_component &       
    characteristic  = cm_angular_displacement

measure create object  &
    measure_name = .model_1.angle_rev2  &
    object       = .model_1.rev2  &            
    component       = z_component &       
    characteristic  = cm_angular_displacement

measure create object  &
    measure_name    = .model_1.spring_force  &
    object          = .model_1.tsd1  & 
    component       = mag_component &              
    characteristic  = element_force


! =============================================================================
! 6. SIMULATION SCRIPT
!    Uses .model_1 (Ctrl+Click → !.model_1 header param, 3rd / 4th usage).
! =============================================================================

simulation script create  &
    sim_script_name = .model_1.run_transient  &
    commands        = "simulation single step end_time=5 number_of_steps=500"

! Run it.
simulation single_run scripted  sim_script_name = .model_1.run_transient

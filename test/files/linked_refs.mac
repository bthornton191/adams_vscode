!USER_ENTERED_COMMAND linked_refs
! =============================================================================
!  linked_refs.mac — Linked Object References Demo
!  ─────────────────────────────────────────────────────────────────────────
!  PURPOSE
!    Demonstrates every kind of navigable reference in the Adams CMD LSP:
!
!    • Macro parameters  ($model, $arm1_name, etc.)
!        Ctrl+Click any usage  → jumps to the !$param definition line
!        Ctrl+Click the def    → shows ALL usages in the peek window
!        Shift+F12 anywhere    → "Find All References" panel
!
!    • Adams object names  (.linked_demo.arm1, .linked_demo.arm1.J1_I, …)
!        Ctrl+Click a name     → jumps to the command that first creates it
!        Ctrl+Click the create → shows all subsequent uses
!
!    • Variable references  ($_self.arm1_len, $_self.stiffness, …)
!        Ctrl+Click a $var     → jumps to the matching  variable set  line
!
!  HOW TO NAVIGATE
!    • Ctrl+Click (or F12)  — Go to Definition / Go to References
!    • Shift+F12            — Find All References
!    • Alt+← / Alt+→        — Navigate back / forward
! =============================================================================
!MACRO NAME:  linked_refs
!HELP_STRING: Build a two-link pendulum with a spring-damper (reference demo)
!AUTHOR:      ben.thornton
!$model:t=model,d=linked_demo
! The model to build into.  Default: linked_demo
!$arm1_name:t=string,d=arm1
! Name for the first (upper) pendulum arm.  Default: arm1
!$arm2_name:t=string,d=arm2
! Name for the second (lower) pendulum arm.  Default: arm2
!$arm_length:t=real,d=300
! Length of each pendulum arm (mm).  Default: 300
!$arm_mass:t=real,d=0.5
! Mass of each arm (kg).  Default: 0.5
!$stiffness:t=real,d=5.0
! Spring stiffness (N/mm).  Default: 5.0
!$damping:t=real,d=0.05
! Damping coefficient (N·s/mm).  Default: 0.05
!END_OF_PARAMETERS

! =============================================================================
! 0. UNITS & MODEL
! =============================================================================

defaults units  &
    length = mm  &
    angle  = deg  &
    force  = newton  &
    mass   = kg  &
    time   = sec

model create model_name = $model     


! =============================================================================
! 1. PARAMETRIC DESIGN VARIABLES
!    Use  variable set  so the LSP can resolve  $_self.xxx  references later.
!    Ctrl+Click any $_self.arm1_len usage below → jumps to this block.
! =============================================================================

variable create  &
    variable_name = $model.arm1_len  &
    real_value    = $arm_length      

variable create  &
    variable_name = $model.arm2_len  &
    real_value    = $arm_length      ! same param, two objects — Shift+F12 shows both

variable create  &
    variable_name = $model.arm_mass  &
    real_value    = $arm_mass

variable create  &
    variable_name = $model.stiffness  &
    real_value    = $stiffness

variable create  &
    variable_name = $model.damping  &
    real_value    = $damping


! =============================================================================
! 2. PARTS & MARKERS
!    Parts use $arm1_name / $arm2_name (Ctrl+Click → !$arm1_name / !$arm2_name).
!    Marker names are Adams object refs — created here, used in §3 and §4.
! =============================================================================

! ── ARM 1 ──────────────────────────────────────────────────────────────────

part create rigid_body name_and_position  &
    part_name = $model.$arm1_name         &    ! ← $arm1_name used here (def 1/N)
    location  = 0, 0, 0

! Centre-of-mass marker at the arm midpoint.
! Ctrl+Click  $model.$arm1_name.cm  anywhere below → jumps to this  marker create.
marker create  &
    marker_name = $model.$arm1_name.cm    &
    location    = (eval($model.arm1_len * 0.5)), 0, 0   ! uses variable $model.arm1_len

part modify rigid_body mass_properties  &
    part_name                = $model.$arm1_name         &
    mass                     = (eval($model.arm_mass))   &
    center_of_mass_marker    = $model.$arm1_name.cm      &   ! ← object ref (Ctrl+Click → marker create above)
    ixx                      = 1  &
    iyy                      = (eval($model.arm_mass * ($model.arm1_len**2) / 12))  &
    izz                      = (eval($model.arm_mass * ($model.arm1_len**2) / 12))

! Pivot marker at the arm root (will be used in the revolute joint).
marker create  &
    marker_name = $model.$arm1_name.pivot_I  &
    location    = 0, 0, 0

! Tip marker — will be referenced as the upper attachment of the spring.
marker create  &
    marker_name = $model.$arm1_name.tip  &
    location    = (eval($model.arm1_len)), 0, 0   ! $model.arm1_len ref 2

! ── ARM 2 ──────────────────────────────────────────────────────────────────

part create rigid_body name_and_position  &
    part_name = $model.$arm2_name  &              ! ← $arm2_name used here
    location  = (eval($model.arm1_len)), 0, 0    ! offset by arm1 length

marker create  &
    marker_name = $model.$arm2_name.cm  &
    location    = (eval($model.arm1_len + $model.arm2_len * 0.5)), 0, 0

part modify rigid_body mass_properties  &
    part_name                = $model.$arm2_name  &
    mass                     = (eval($model.arm_mass))  &
    center_of_mass_marker    = $model.$arm2_name.cm  &
    ixx                      = 1  &
    iyy                      = (eval($model.arm_mass * ($model.arm2_len**2) / 12))  &
    izz                      = (eval($model.arm_mass * ($model.arm2_len**2) / 12))

! Root pivot of arm2 — mounts onto the tip of arm1.
marker create  &
    marker_name = $model.$arm2_name.pivot_I  &
    location    = (eval($model.arm1_len)), 0, 0

! Spring attachment marker at arm2 midpoint.
marker create  &
    marker_name = $model.$arm2_name.spring_J  &
    location    = (eval($model.arm1_len + $model.arm2_len * 0.5)), 0, 0


! =============================================================================
! 3. CONSTRAINTS
!    Ctrl+Click on joint I/J markers → back to the  marker create  lines above.
! =============================================================================

! Ground pivot for arm1 — uses  $model.$arm1_name.pivot_I
constraint create joint revolute  &
    joint_name = $model.rev1         &
    i_marker   = $model.$arm1_name.pivot_I  &   
    j_marker   = ground.ref_point

! Elbow pivot between arm1 tip and arm2 root.
! Ctrl+Click  $model.$arm1_name.tip  → tip marker created in §2.
constraint create joint revolute  &
    joint_name = $model.rev2         &
    i_marker   = $model.$arm1_name.tip       &   ! ← second use of .tip marker
    j_marker   = $model.$arm2_name.pivot_I


! =============================================================================
! 4. FORCES
!    Spring-damper between arm1 tip and arm2 midpoint.
!    Uses $stiffness and $damping params (Ctrl+Click → !$stiffness / !$damping).
!    Also uses $model.stiffness / $model.damping variables (Ctrl+Click → §1 var create).
! =============================================================================

force create element translational_spring_damper  &
    spring_damper_name          = $model.tsd1             &
    i_marker                    = $model.$arm1_name.tip   &   
    j_marker                    = $model.$arm2_name.spring_J  &
    stiffness                   = (eval($model.stiffness))    &   
    damping                     = (eval($model.damping))      &   
    displacement_at_preload     = (eval($model.arm2_len * 0.5))



! =============================================================================
! 5. MEASURES
!    Measure the angle at each joint and the spring deformation.
!    Object names ($model.rev1, $model.rev2, $model.tsd1) all Ctrl+Click back
!    to their creation commands in §3 / §4.
! =============================================================================

measure create object  &
    measure_name    = $model.angle_rev1  &
    object          = $model.rev1  &         
    component       = z_component &       
    characteristic  = cm_angular_displacement

measure create object  &
    measure_name = $model.angle_rev2  &
    object       = $model.rev2  &            
    component       = z_component &       
    characteristic  = cm_angular_displacement

measure create object  &
    measure_name    = $model.spring_force  &
    object          = $model.tsd1  & 
    component       = mag_component &              
    characteristic  = element_force


! =============================================================================
! 6. SIMULATION SCRIPT
!    Uses $model (Ctrl+Click → !$model header param, 3rd / 4th usage).
! =============================================================================

simulation script create  &
    sim_script_name = $model.run_transient  &
    commands        = "simulation single step end_time=5 number_of_steps=500"

! Run it.
simulation single_run scripted  sim_script_name = $model.run_transient

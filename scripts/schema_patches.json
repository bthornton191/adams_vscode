    "constraint create joint hooke": {
      "exclusive_groups": [
        {"group": 1, "members": ["i_marker_name", "i_part_name"]},
        {"group": 2, "members": ["j_marker_name", "j_part_name"]}
      ]
    },
    "constraint modify joint general": {
      "exclusive_groups": [
        {"group": 1, "members": ["i_marker_name", "i_part_name"]},
        {"group": 2, "members": ["j_marker_name", "j_part_name"]}

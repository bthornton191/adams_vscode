    "force create direct single_component_force": {
      "exclusive_groups": [
        {"group": 1, "members": ["function", "user_function"]},
        {"group": 2, "members": ["i_marker_name", "i_part_name"]},
        {"group": 3, "members": ["j_marker_name", "j_part_name"]}
      ]
    },
    "part create equation differential_equation": {

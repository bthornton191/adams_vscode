! ============================================================
! Macro:  export_results
! Purpose: Export a named analysis result (request) to a
!          tab-delimited text file for post-processing.
!
!   - Demonstrates output parameters (caller-supplied variable name)
!   - Uses UNIQUE_NAME() for temp objects
!   - Uses DB_ANCESTOR() to resolve owning model
!   - Uses the file I/O pattern (write commands to temp .cmd, read back)
!   - Cleans up all temporaries and temp files on exit
!
! Usage:
!   export_results &
!     analysis = .model.Last_Run &
!     request   = .model.my_request &
!     out_file  = "C:/output/my_results.txt"
! ============================================================
!
!USER_ENTERED_COMMAND  export_results
!HELP_STRING           Export a simulation request to a text file
!CREATE_PANEL          no
!WRAP_IN_UNDO          no
!
!$analysis:t=analysis:c=1
!$request:t=string:c=1
!$out_file:t=file(*.txt):c=1
!$component:t=list(X,Y,Z,MAG,ALL):c=0:d=ALL
!
!END_OF_PARAMETERS
! ============================================================

! Always bind at least one $_self variable immediately
variable set variable_name = $_self._init  integer_value = 1

! Resolve the owning model
variable set variable_name = $_self.mdl &
    string_value = (DB_ANCESTOR("$analysis", "model"))

! Build a unique name for the temporary writable file
variable set variable_name = $_self.tmp &
    string_value = (UNIQUE_NAME("tmp_exp_"))

variable set variable_name = $_self.cmd_file &
    string_value = ($_self.tmp // ".cmd")

variable set variable_name = $_self.dat_file &
    string_value = "$out_file"

! Guard: check the request exists before proceeding
if condition = (1 - DB_EXISTS("$request"))
    variable set variable_name = $_self.err &
        string_value = ("Request not found: $request — aborting export.")

    interface message &
        message = (eval($_self.err)) &
        severity=error

    variable delete variable = $_self.*
    return
end

! Write the export command to a temporary .cmd file
file text open &
    file_name  = (eval($_self.cmd_file)) &
    open_mode  = overwrite

file text write &
    file_name         = (eval($_self.cmd_file)) &
    format_for_output = "output results request &"

file text write &
    file_name         = (eval($_self.cmd_file)) &
    format_for_output = "    analysis_name = %s &" &
    values_for_output = "$analysis"

file text write &
    file_name         = (eval($_self.cmd_file)) &
    format_for_output = "    request_name  = %s &" &
    values_for_output = "$request"

file text write &
    file_name         = (eval($_self.cmd_file)) &
    format_for_output = "    component     = %s &" &
    values_for_output = "$component"

file text write &
    file_name         = (eval($_self.cmd_file)) &
    format_for_output = "%s" &
    values_for_output = ("    file_name     = " // chr(34) // eval($_self.dat_file) // chr(34))

file text close file_name = (eval($_self.cmd_file))

! Execute the generated export command
file command read file_name = (eval($_self.cmd_file))

interface message message = ("Exported results to: " // eval($_self.dat_file))

! Note: Adams View CMD has no file delete command.
! The temp .cmd file will remain on disk; clean up manually if needed.

! Clean up all in-memory temporaries
variable delete variable = $_self.*

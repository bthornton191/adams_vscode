! ============================================================
! Macro:  batch_spring
! Purpose: Create a spring-damper between every consecutive
!          pair of markers in a supplied list.
!
!   - Demonstrates typed parameters (marker list, real, integer)
!   - Uses $_self variable scoping
!   - Guards spring creation with DB_EXISTS
!   - Cleans up all temporaries on exit
!
! Usage (two-marker example):
!   batch_spring &
!     markers = .model.body_a.mkr_1, .model.body_b.mkr_2 &
!     stiffness = 500.0 &
!     damping   = 5.0
! ============================================================
!
!USER_ENTERED_COMMAND  batch_spring
!HELP_STRING           Create spring-dampers between pairs of markers
!CREATE_PANEL          no
!WRAP_IN_UNDO          yes
!
!$markers:t=marker:c=2,100
!$stiffness:t=real:c=1:d=1000.0:r=gt(0)
!$damping:t=real:c=0:d=10.0:r=ge(0)
!$free_length:t=real:c=0:d=0.0:r=ge(0)
!$name_prefix:t=string:c=0:d="spr_"
!
!END_OF_PARAMETERS
! ============================================================

! Always create at least one $_self variable before any early-exit
variable set variable_name = $_self._init        integer_value = 1
variable set variable_name = $_self.stiffness    real_value    = $stiffness
variable set variable_name = $_self.damping      real_value    = $damping
variable set variable_name = $_self.free_length  real_value    = $free_length
variable set variable_name = $_self.prefix       string_value  = "$name_prefix"
variable set variable_name = $_self.count        integer_value = 0

! Iterate over consecutive marker pairs (1,2), (2,3), ...
! Adams passes a multi-value parameter as an array; index with [n]
for variable_name = i  start_value = 1  end_value = (eval(COUNT($markers) - 1))

    variable set variable_name = $_self.mkr_i   object_value = (eval($markers[i]))
    variable set variable_name = $_self.mkr_j   object_value = (eval($markers[i+1]))
    variable set variable_name = $_self.count   integer_value = (eval($_self.count) + 1)

    ! Build a unique spring name
    variable set variable_name = $_self.spr_name &
        string_value = (UNIQUE_NAME(DB_ANCESTOR(eval($_self.mkr_i), "model") // "." // $_self.prefix))

    ! Skip if this spring already exists (e.g. re-running the macro)
    if condition = (DB_EXISTS(eval($_self.spr_name)))
        interface message &
            message = ("Skipping existing spring: " // eval($_self.spr_name))
    end

    if condition = (1 - DB_EXISTS(eval($_self.spr_name)))
        force create element_like translational_spring_damper &
            spring_damper_name      = (eval($_self.spr_name)) &
            i_marker_name           = (eval($_self.mkr_i)) &
            j_marker_name           = (eval($_self.mkr_j)) &
            stiffness               = (eval($_self.stiffness)) &
            damping                 = (eval($_self.damping)) &
            displacement_at_preload = (eval($_self.free_length))

        interface message &
            message = ("Created spring: " // eval($_self.spr_name))
    end

end

interface message message = (RTOI($_self.count) // " spring(s) processed.")

! Clean up all temporaries
variable delete variable = $_self.*

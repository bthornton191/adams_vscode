! enable-eprint.acf
! Purpose: Enable EPRINT diagnostic output for a short diagnostic run,
!          then disable it to avoid excessive output for the rest of the simulation.
!
! Usage: Include at the top of your .acf file, before the first SIMULATE command.
! Adjust end= to run just past the point where the simulation fails.

! --- Enable diagnostic output ---
DEBUG/EPRINT

! --- Run a short diagnostic pass ---
SIMULATE/DYNAMIC, END=0.5, STEPS=50

! --- Read the .msg file output now ---
! Look for lines starting with ">>> C" (corrector) and ">>> P" (predictor)
! Note: last column = element with largest residual (e.g. "CONTACT 7", "DIFF 12")
! Note: 4th column = residual error; 5th column = largest state correction

! --- Disable EPRINT for the full run if needed ---
DEBUG/NOEPRINT

! --- Proceed with full simulation ---
! SIMULATE/DYNAMIC, END=10.0, STEPS=1000

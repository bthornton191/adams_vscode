! robust-dynamic-settings.acf
! Purpose: Apply a robust set of integrator settings for dynamic simulations
!          that have contact, friction, or discontinuous force elements.
!
! These settings trade some simulation speed for significantly improved robustness.
! Start here when a dynamic simulation fails with "HMIN exceeded".

! ====================================================
! Integrator: SI2 + MODIFIED corrector
! - SI2 improves velocity accuracy over default I3
! - MODIFIED corrector re-evaluates Jacobian every iteration
!   (critical for contact and nonlinear force elements)
! - ERROR=1e-4 is tighter than default (1e-3) for better accuracy
! - HMAX limits step size through contact events
! ====================================================
INTEGRATOR/GSTIFF, SI2,            &
           CORRECTOR=MODIFIED,    &
           ERROR=1e-4,            &
           HMAX=1e-4,             &
           HMIN=1e-12,            &
           KMAX=6,                &
           MAXIT=10

! ====================================================
! Equilibrium: Use ADVANCED method as default
! (runs faster with automatic fallback to Trust-Region)
! ====================================================
EQUILIBRIUM/METHOD=ADVANCED, &
            STABILITY=1e-5,   &
            ERROR=1e-4,       &
            IMBALANCE=1e-4

! ====================================================
! Run the simulation
! Adjust end and steps to your model
! ====================================================
SIMULATE/DYNAMIC, END=2.0, STEPS=200
